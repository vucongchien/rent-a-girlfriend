{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Rent-a-Girlfriend CloudEvents Schema",
  "description": "JSON Schema defining standard CloudEvents v1.0 envelope and domain-specific payloads.",
  "type": "object",
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "datacontenttype",
    "time",
    "data"
  ],
  "properties": {
    "specversion": {
      "type": "string",
      "enum": ["1.0"]
    },
    "id": {
      "type": "string",
      "description": "Unique UUID for the event. Used for Consumer Idempotency check."
    },
    "source": {
      "type": "string",
      "description": "URI-reference identifying the context where event happened.",
      "example": "/rent-a-gf/booking-context/booking/bk_999"
    },
    "type": {
      "type": "string",
      "description": "Domain event type standard format: [domain].[context].[EventName].[version]",
      "pattern": "^com\\.rentagf\\.[a-z]+\\.[A-Za-z]+(\\.v[0-9]+)$"
    },
    "datacontenttype": {
      "type": "string",
      "enum": ["application/json"]
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "description": "Domain-specific payload.",
      "oneOf": [
        { "$ref": "#/definitions/BookingRequestedPayload" },
        { "$ref": "#/definitions/BookingAcceptedPayload" },
        { "$ref": "#/definitions/BookingRejectedPayload" },
        { "$ref": "#/definitions/BookingCancelledPayload" },
        { "$ref": "#/definitions/BookingAcceptSagaFailedPayload" },
        { "$ref": "#/definitions/CoinFrozenPayload" },
        { "$ref": "#/definitions/CoinEscrowedPayload" },
        { "$ref": "#/definitions/KanoCoinDepositedPayload" },
        { "$ref": "#/definitions/DepositFailedPayload" },
        { "$ref": "#/definitions/PayoutProcessedPayload" },
        { "$ref": "#/definitions/ChatRoomCreatedPayload" },
        { "$ref": "#/definitions/ReviewSubmittedPayload" },
        { "$ref": "#/definitions/ReportCreatedPayload" },
        { "$ref": "#/definitions/DisputeResolvedPayload" },
        { "$ref": "#/definitions/ViolationRecordedPayload" },
        { "$ref": "#/definitions/AccountLockedPayload" },
        { "$ref": "#/definitions/ProfileCreatedPayload" },
        { "$ref": "#/definitions/ProfileUpdatedPayload" },
        { "$ref": "#/definitions/ProfileApprovedPayload" },
        { "$ref": "#/definitions/ProfileRejectedPayload" },
        { "$ref": "#/definitions/ScenarioCreatedPayload" },
        { "$ref": "#/definitions/ScenarioUpdatedPayload" },
        { "$ref": "#/definitions/ScenarioDeletedPayload" },
        { "$ref": "#/definitions/ScenarioRejectedPayload" },
        { "$ref": "#/definitions/VoiceIntroUploadedPayload" },
        { "$ref": "#/definitions/VoiceIntroRejectedPayload" },
        { "$ref": "#/definitions/AlbumImageUploadedPayload" },
        { "$ref": "#/definitions/AlbumImageRejectedPayload" },
        { "$ref": "#/definitions/UpgradeApprovedPayload" },
        { "$ref": "#/definitions/UpgradeRejectedPayload" }
      ]
    },
    "extensions": {
      "type": "object",
      "properties": {
        "correlationId": {
          "type": "string",
          "description": "Used for cross-service distributed tracing."
        }
      },
      "required": ["correlationId"]
    }
  },
  "definitions": {
    "BookingRequestedPayload": {
      "type": "object",
      "required": ["bookingId", "clientId", "companionId", "price", "startTime"],
      "properties": {
        "bookingId": { "type": "string", "format": "uuid" },
        "clientId": { "type": "string", "format": "uuid" },
        "companionId": { "type": "string", "format": "uuid" },
        "price": { "type": "integer", "minimum": 1 },
        "startTime": { "type": "string", "format": "date-time" },
        "sagaId": { "type": "string", "format": "uuid" }
      }
    },
    "BookingAcceptedPayload": {
      "type": "object",
      "required": ["bookingId", "clientId", "companionId", "price", "sagaId"],
      "properties": {
        "bookingId": { "type": "string", "format": "uuid" },
        "clientId": { "type": "string", "format": "uuid", "description": "ID của Client nhận thông báo đặt lịch được chấp nhận" },
        "companionId": { "type": "string", "format": "uuid" },
        "price": { "type": "integer", "minimum": 1 },
        "sagaId": { "type": "string", "format": "uuid" }
      }
    },
    "BookingRejectedPayload": {
      "type": "object",
      "required": ["bookingId", "clientId", "companionId", "reason"],
      "properties": {
        "bookingId": { "type": "string", "format": "uuid" },
        "clientId": { "type": "string", "format": "uuid", "description": "ID của Client nhận thông báo từ chối đặt lịch" },
        "companionId": { "type": "string", "format": "uuid", "description": "ID của Companion từ chối đặt lịch" },
        "reason": { "type": "string", "description": "Lý do từ chối đặt lịch" }
      }
    },
    "BookingCancelledPayload": {
      "type": "object",
      "required": ["bookingId", "clientId", "companionId", "actorRole", "isLate"],
      "properties": {
        "bookingId": { "type": "string", "format": "uuid" },
        "clientId": { "type": "string", "format": "uuid", "description": "ID của Client liên quan đến booking hủy" },
        "companionId": { "type": "string", "format": "uuid", "description": "ID của Companion liên quan đến booking hủy" },
        "actorRole": { "type": "string", "enum": ["CLIENT", "COMPANION"] },
        "isLate": { 
          "type": "boolean",
          "description": "True if cancelled under 24 hours prior to startTime (BR-06, BR-07a)."
        }
      }
    },
    "BookingAcceptSagaFailedPayload": {
      "type": "object",
      "required": ["bookingId", "clientId", "companionId", "reason"],
      "properties": {
        "bookingId": { "type": "string", "format": "uuid" },
        "clientId": { "type": "string", "format": "uuid", "description": "ID của Client nhận thông báo rollback giao dịch do lỗi hệ thống" },
        "companionId": { "type": "string", "format": "uuid", "description": "ID của Companion liên quan đến sự kiện lỗi SAGA" },
        "reason": { "type": "string", "description": "Lý do lỗi trong luồng SAGA chấp nhận đặt lịch" }
      }
    },
    "KanoCoinDepositedPayload": {
      "type": "object",
      "required": ["transactionId", "userId", "amount"],
      "properties": {
        "transactionId": { "type": "string", "format": "uuid" },
        "userId": { "type": "string", "format": "uuid", "description": "ID của User (Khách hàng) nhận thông báo nạp tiền thành công" },
        "amount": { "type": "integer", "description": "Số lượng Kano-Coin nạp thành công" }
      }
    },
    "DepositFailedPayload": {
      "type": "object",
      "required": ["transactionId", "userId", "amount", "reason"],
      "properties": {
        "transactionId": { "type": "string", "format": "uuid" },
        "userId": { "type": "string", "format": "uuid", "description": "ID của User (Khách hàng) nhận thông báo nạp tiền thất bại" },
        "amount": { "type": "integer", "description": "Số lượng Kano-Coin nạp lỗi" },
        "reason": { "type": "string", "description": "Lý do nạp tiền thất bại" }
      }
    },
    "CoinFrozenPayload": {
      "type": "object",
      "required": ["walletId", "amount", "refId"],
      "properties": {
        "walletId": { "type": "string", "format": "uuid" },
        "amount": { "type": "integer" },
        "refId": { "type": "string", "format": "uuid", "description": "Associated booking ID" }
      }
    },
    "CoinEscrowedPayload": {
      "type": "object",
      "required": ["bookingId", "amount"],
      "properties": {
        "bookingId": { "type": "string", "format": "uuid" },
        "amount": { "type": "integer" }
      }
    },
    "PayoutProcessedPayload": {
      "type": "object",
      "required": ["bookingId", "companionId", "payoutAmount", "commissionAmount"],
      "properties": {
        "bookingId": { "type": "string", "format": "uuid" },
        "companionId": { "type": "string", "format": "uuid", "description": "ID của Companion nhận thanh toán thu nhập" },
        "payoutAmount": { "type": "integer", "description": "Net amount paid to companion (BR-03 commission deduction)." },
        "commissionAmount": { "type": "integer", "description": "Amount withheld by system." }
      }
    },
    "ChatRoomCreatedPayload": {
      "type": "object",
      "required": ["roomId", "bookingId", "clientUserId", "companionUserId"],
      "properties": {
        "roomId": { "type": "string", "format": "uuid" },
        "bookingId": { "type": "string", "format": "uuid" },
        "clientUserId": { "type": "string", "format": "uuid" },
        "companionUserId": { "type": "string", "format": "uuid" }
      }
    },
    "ReviewSubmittedPayload": {
      "type": "object",
      "required": ["reviewId", "bookingId", "clientId", "companionId", "rating"],
      "properties": {
        "reviewId": { "type": "string", "format": "uuid" },
        "bookingId": { "type": "string", "format": "uuid" },
        "clientId": { "type": "string", "format": "uuid" },
        "companionId": { "type": "string", "format": "uuid" },
        "rating": { "type": "integer", "minimum": 1, "maximum": 5 }
      }
    },
    "ReportCreatedPayload": {
      "type": "object",
      "required": ["disputeId", "bookingId", "reporterId", "accusedId", "reason"],
      "properties": {
        "disputeId": { "type": "string", "format": "uuid" },
        "bookingId": { "type": "string", "format": "uuid" },
        "reporterId": { "type": "string", "format": "uuid" },
        "accusedId": { "type": "string", "format": "uuid", "description": "ID của Companion bị tố cáo nhận cảnh báo" },
        "reason": { "type": "string", "enum": ["NO_SHOW", "MISCONDUCT"] }
      }
    },
    "DisputeResolvedPayload": {
      "type": "object",
      "required": ["disputeId", "bookingId", "clientId", "companionId", "resolution"],
      "properties": {
        "disputeId": { "type": "string", "format": "uuid" },
        "bookingId": { "type": "string", "format": "uuid" },
        "clientId": { "type": "string", "format": "uuid", "description": "ID của Client nhận kết quả giải quyết khiếu nại" },
        "companionId": { "type": "string", "format": "uuid", "description": "ID của Companion nhận kết quả giải quyết khiếu nại" },
        "resolution": { "type": "string", "description": "Chi tiết kết quả giải quyết tranh chấp" }
      }
    },
    "ViolationRecordedPayload": {
      "type": "object",
      "required": ["userId", "currentCount"],
      "properties": {
        "userId": { "type": "string", "format": "uuid" },
        "currentCount": { "type": "integer", "description": "Current violation count before policy evaluation." }
      }
    },
    "AccountLockedPayload": {
      "type": "object",
      "required": ["userId", "reason"],
      "properties": {
        "userId": { "type": "string", "format": "uuid" },
        "reason": { "type": "string", "example": "Exceeded maximum violation count." }
      }
    },
    "ProfileCreatedPayload": {
      "type": "object",
      "required": ["companionId", "userId", "displayName", "availableCities"],
      "properties": {
        "companionId": { "type": "string", "format": "uuid" },
        "userId": { "type": "string", "format": "uuid" },
        "displayName": { "type": "string" },
        "availableCities": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "ProfileUpdatedPayload": {
      "type": "object",
      "required": ["companionId", "displayName", "availableCities"],
      "properties": {
        "companionId": { "type": "string", "format": "uuid" },
        "displayName": { "type": "string" },
        "introText": { "type": "string" },
        "availableCities": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "ProfileApprovedPayload": {
      "type": "object",
      "required": ["companionId", "approvedBy"],
      "properties": {
        "companionId": { "type": "string", "format": "uuid" },
        "approvedBy": { "type": "string", "format": "uuid" }
      }
    },
    "ProfileRejectedPayload": {
      "type": "object",
      "required": ["companionId", "rejectedBy", "reason"],
      "properties": {
        "companionId": { "type": "string", "format": "uuid" },
        "rejectedBy": { "type": "string", "format": "uuid" },
        "reason": { "type": "string" }
      }
    },
    "ScenarioCreatedPayload": {
      "type": "object",
      "required": ["scenarioId", "companionId", "title", "price", "durationMinutes"],
      "properties": {
        "scenarioId": { "type": "string", "format": "uuid" },
        "companionId": { "type": "string", "format": "uuid" },
        "title": { "type": "string" },
        "price": { "type": "integer", "minimum": 1 },
        "durationMinutes": { "type": "integer", "enum": [60, 120, 180] }
      }
    },
    "ScenarioUpdatedPayload": {
      "type": "object",
      "required": ["scenarioId", "companionId", "title", "price", "durationMinutes", "status"],
      "properties": {
        "scenarioId": { "type": "string", "format": "uuid" },
        "companionId": { "type": "string", "format": "uuid" },
        "title": { "type": "string" },
        "price": { "type": "integer", "minimum": 1 },
        "durationMinutes": { "type": "integer", "enum": [60, 120, 180] },
        "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] }
      }
    },
    "ScenarioDeletedPayload": {
      "type": "object",
      "required": ["scenarioId", "companionId"],
      "properties": {
        "scenarioId": { "type": "string", "format": "uuid" },
        "companionId": { "type": "string", "format": "uuid" }
      }
    },
    "ScenarioRejectedPayload": {
      "type": "object",
      "required": ["scenarioId", "companionId", "reason"],
      "properties": {
        "scenarioId": { "type": "string", "format": "uuid" },
        "companionId": { "type": "string", "format": "uuid", "description": "ID của Companion nhận thông báo kịch bản bị từ chối" },
        "reason": { "type": "string", "description": "Lý do kịch bản bị từ chối" }
      }
    },
    "VoiceIntroUploadedPayload": {
      "type": "object",
      "required": ["companionId", "assetId", "fileUrl", "durationSeconds", "sizeBytes"],
      "properties": {
        "companionId": { "type": "string", "format": "uuid" },
        "assetId": { "type": "string", "format": "uuid" },
        "fileUrl": { "type": "string", "format": "uri" },
        "durationSeconds": { "type": "integer", "maximum": 30 },
        "sizeBytes": { "type": "integer", "maximum": 5242880 }
      }
    },
    "VoiceIntroRejectedPayload": {
      "type": "object",
      "required": ["companionId", "fileUrl", "reason"],
      "properties": {
        "companionId": { "type": "string", "format": "uuid" },
        "fileUrl": { "type": "string", "format": "uri" },
        "reason": { "type": "string" }
      }
    },
    "AlbumImageUploadedPayload": {
      "type": "object",
      "required": ["companionId", "assetId", "fileUrl", "sizeBytes"],
      "properties": {
        "companionId": { "type": "string", "format": "uuid" },
        "assetId": { "type": "string", "format": "uuid" },
        "fileUrl": { "type": "string", "format": "uri" },
        "sizeBytes": { "type": "integer", "maximum": 2097152 }
      }
    },
    "AlbumImageRejectedPayload": {
      "type": "object",
      "required": ["companionId", "fileUrl", "reason"],
      "properties": {
        "companionId": { "type": "string", "format": "uuid", "description": "ID của Companion nhận thông báo ảnh album bị từ chối" },
        "fileUrl": { "type": "string", "format": "uri" },
        "reason": { "type": "string", "description": "Lý do ảnh bị từ chối" }
      }
    },
    "UpgradeApprovedPayload": {
      "type": "object",
      "required": ["userId", "requestId", "approvedBy"],
      "properties": {
        "userId": { "type": "string", "format": "uuid", "description": "ID của User nhận thông báo nâng cấp thành Companion thành công" },
        "requestId": { "type": "string", "format": "uuid" },
        "approvedBy": { "type": "string", "format": "uuid" }
      }
    },
    "UpgradeRejectedPayload": {
      "type": "object",
      "required": ["userId", "requestId", "rejectedBy", "reason"],
      "properties": {
        "userId": { "type": "string", "format": "uuid", "description": "ID của User nhận thông báo từ chối nâng cấp" },
        "requestId": { "type": "string", "format": "uuid" },
        "rejectedBy": { "type": "string", "format": "uuid" },
        "reason": { "type": "string", "description": "Lý do từ chối nâng cấp" }
      }
    }
  }
}
